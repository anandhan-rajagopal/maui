<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Maui.Controls.Sample"
             x:Class="Maui.Controls.Sample.ProgressBarOptionsPage"
             x:DataType="local:ProgressBarViewModel"
             Title="ProgressBarFeature">
       <ContentPage.ToolbarItems>
              <ToolbarItem Text="Apply"
                           Clicked="ApplyButton_Clicked"
                           AutomationId="Apply"/>
       </ContentPage.ToolbarItems>

       <Grid Padding="10"
             ColumnDefinitions="Auto, Auto"
             RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto"
             RowSpacing="10"
             ColumnSpacing="5">

              <!-- Progress -->
              <Label Grid.Row="0"
                     Grid.Column="0"
                     Text="{Binding Progress, StringFormat='Progress {0:F2}'}"
                     FontSize="15"
                     VerticalOptions="Center"/>
              <Entry Grid.Row="0"
                     Grid.Column="1"
                     x:Name="ProgressEntry"
                     AutomationId="ProgressEntry"
                     TextChanged="OnProgressChanged"
                     Keyboard="Numeric"
                     VerticalOptions="Center"
                     WidthRequest="100"/>

              <!-- Flow Direction -->
              <Label Grid.Row="1"
                     Grid.Column="0"
                     Text="Flow Direction:"
                     FontSize="15"
                     VerticalOptions="Center"/>
              <StackLayout Grid.Row="1"
                           Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalOptions="Center">
                     <RadioButton AutomationId="FlowDirectionLeftToRightButton"
                                  GroupName="FlowDirection"
                                  Content="LeftToRight"
                                  CheckedChanged="OnFlowDirectionChanged"
                                  IsChecked="True"/>
                     <RadioButton AutomationId="FlowDirectionRightToLeftButton"
                                  GroupName="FlowDirection"
                                  Content="RightToLeft"
                                  CheckedChanged="OnFlowDirectionChanged"/>
              </StackLayout>

              <!-- Is Visible -->
              <Label Grid.Row="2"
                     Grid.Column="0"
                     Text="Is Visible:"
                     FontSize="15"
                     VerticalOptions="Center"/>
              <StackLayout Grid.Row="2"
                           Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalOptions="Center">
                     <RadioButton GroupName="IsVisible"
                                  AutomationId="IsVisibleTrueButton"
                                  Content="True"
                                  CheckedChanged="OnIsVisibleRadioButtonCheckedChanged"
                                  IsChecked="True"/>
                     <RadioButton GroupName="IsVisible"
                                  AutomationId="IsVisibleFalseButton"
                                  Content="False"
                                  CheckedChanged="OnIsVisibleRadioButtonCheckedChanged"/>
              </StackLayout>

              <!-- Progress Color -->
              <Label Grid.Row="3"
                     Grid.Column="0"
                     Text="Progress Color:"
                     FontSize="15"
                     VerticalOptions="Center"/>
              <StackLayout Grid.Row="3"
                           Grid.Column="1"
                           Orientation="Horizontal"
                           Spacing="5"
                           VerticalOptions="Center">
                     <Button Text="Blue"
                             BackgroundColor="Blue"
                             TextColor="White"
                             Clicked="ProgressColorButton_Clicked"
                             AutomationId="ProgressColorBlueButton"/>
                     <Button Text="Green"
                             BackgroundColor="Green"
                             TextColor="White"
                             Clicked="ProgressColorButton_Clicked"
                             AutomationId="ProgressColorGreenButton"/>
              </StackLayout>

              <!-- Background Color -->
              <Label Grid.Row="4"
                     Grid.Column="0"
                     Text="Background Color:"
                     FontSize="15"
                     VerticalOptions="Center"/>
              <StackLayout Grid.Row="4"
                           Grid.Column="1"
                           Orientation="Horizontal"
                           Spacing="5"
                           VerticalOptions="Center">
                     <Button Text="Red"
                             BackgroundColor="Red"
                             TextColor="White"
                             Clicked="BackgroundColorButton_Clicked"
                             AutomationId="BackgroundColorRedButton"/>
                     <Button Text="Light Blue"
                             BackgroundColor="LightBlue"
                             TextColor="White"
                             Clicked="BackgroundColorButton_Clicked"
                             AutomationId="BackgroundColorLightBlueButton"/>
              </StackLayout>

              <!-- Shadow -->
              <Label Grid.Row="5"
                     Grid.Column="0"
                     Text="Shadow:"
                     VerticalOptions="Center"/>
              <StackLayout Grid.Row="5"
                           Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalOptions="Center">
                     <RadioButton GroupName="Shadow"
                                  AutomationId="ShadowTrueButton"
                                  Content="True"
                                  CheckedChanged="OnShadowRadioButtonCheckedChanged"
                                  Value="1"/>
                     <RadioButton GroupName="Shadow"
                                  AutomationId="ShadowFalseButton"
                                  Content="False"
                                  CheckedChanged="OnShadowRadioButtonCheckedChanged"
                                  Value="0"/>
              </StackLayout>
       </Grid>
</ContentPage>
