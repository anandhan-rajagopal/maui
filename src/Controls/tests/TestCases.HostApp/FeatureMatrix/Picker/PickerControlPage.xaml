<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Maui.Controls.Sample"
             x:Class="Maui.Controls.Sample.PickerControlMainPage"
             Title="PickerControlPage">
       <ContentPage.ToolbarItems>
              <ToolbarItem Text="Options"
                           Clicked="NavigateToOptionsPage_Clicked"
                           AutomationId="Options"/>
       </ContentPage.ToolbarItems>
       <Grid RowDefinitions="Auto, Auto, Auto"
             ColumnDefinitions="0.5*, 0.5*"
             RowSpacing="10"
             Padding="20">
              <Picker x:Name="Picker"
                      Grid.Row="0"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      AutomationId="PickerControl"
                      CharacterSpacing="{Binding CharacterSpacing}"
                      FontAttributes="{Binding FontAttributes}"
                      FontAutoScalingEnabled="{Binding FontAutoScalingEnabled}"
                      FontFamily="{Binding FontFamily}"
                      FontSize="{Binding FontSize}"
                      HorizontalTextAlignment="{Binding HorizontalTextAlignment}"
                      HeightRequest="100"
                      ItemsSource="{Binding ItemsSource}"
                      ItemDisplayBinding="{Binding .}"
                      SelectedIndex="{Binding SelectedIndex}"
                      SelectedItem="{Binding SelectedItem}"
                      TextColor="{Binding TextColor}"
                      Title="{Binding Title}"
                      TitleColor="{Binding TitleColor}"
                      VerticalTextAlignment="{Binding VerticalTextAlignment}">
              </Picker>

              <Label Grid.Row="1"
                     Grid.Column="0"
                     Text="SelectedIndex:"
                     FontSize="20"
                     HorizontalOptions="Start"
                     VerticalOptions="CenterAndExpand"/>
              <Label Grid.Row="1"
                     Grid.Column="1"
                     AutomationId="SelectedIndexLabel"
                     Text="{Binding SelectedIndex}"
                     FontSize="20"
                     HorizontalOptions="Center"
                     VerticalOptions="CenterAndExpand"/>
              <Label Grid.Row="2"
                     Grid.Column="0"
                     Text="SelectedItem:"
                     FontSize="20"
                     HorizontalOptions="Start"
                     VerticalOptions="CenterAndExpand"/>
              <Label Grid.Row="2"
                     Grid.Column="1"
                     AutomationId="SelectedItemLabel"
                     Text="{Binding SelectedItem}"
                     FontSize="20"
                     HorizontalOptions="Center"
                     VerticalOptions="CenterAndExpand"/>
       </Grid>

</ContentPage>